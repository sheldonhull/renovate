{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    ':dependencyDashboard',
    ':semanticPrefixFixDepsChoreOthers',
    ':ignoreModulesAndTests',
    'replacements:all',
    'workarounds:all',
    'schedule:earlyMondays',
    ':semanticCommitTypeAll(chore)',
    'github>whitesource/merge-confidence:beta',
    'github>aquaproj/aqua-renovate-config#1.13.0',
    'github>aquaproj/aqua-renovate-config:installer-script#1.13.0(scripts/.*\\.sh)',
    'github>aquaproj/aqua-renovate-config:installer-script#1.13.0(netlify\\.toml)',
    'github>aquaproj/aqua-renovate-config:installer-script#1.13.0(.*Dockerfile)',
    'github>aquaproj/aqua-renovate-config:aqua-renovate-config#1.13.0(default\\.json5)',
    'helpers:pinGitHubActionDigests',
    ':enableVulnerabilityAlerts',
    'group:linters',
    ':combinePatchMinorReleases',
    'github>sheldonhull/renovate:group-by-manager.json',
  ],
  labels: [
    'dependencies',
  ],
  dependencyDashboard: true,
  dependencyDashboardLabels: [
    'dependencies',
  ],
  prBodyTemplate: '{{{header}}}{{{table}}}{{{warnings}}}{{{notes}}}{{{url}}}{{{configDescription}}}{{{controls}}}{{{footer}}}',
  binarySource: 'docker',
  semanticCommits: 'enabled',
  pruneStaleBranches: true,
  rebaseWhen: 'behind-base-branch',
  semanticCommitType: 'chore',
  semanticCommitScope: 'deps',
  unicodeEmoji: true,
  rangeStrategy: 'pin',
  postUpdateOptions: [
    'gomodTidy',
    'gomodUpdateImportPaths',
  ],
  prCreation: 'immediate',
  onboardingPrTitle: 'chore(deps): onboard with renovate',
  // Defaults: auto-approve, automerge, squash strategy, 7 day stability window
  autoApprove: true,
  automerge: true,
  automergeStrategy: 'squash',
  platformAutomerge: true,
  minimumReleaseAge: '7 days',
  // Major changes require manual approval and review from sheldonhull
  major: {
    dependencyDashboardApproval: true,
    autoApprove: false,
    automerge: false,
    reviewers: [
      'sheldonhull',
    ],
  },
  // Security updates: always approved + automerged with squash, no stability wait
  vulnerabilityAlerts: {
    enabled: true,
    prCreation: 'immediate',
    labels: [
      'security',
    ],
    minimumReleaseAge: null,
    dependencyDashboardApproval: false,
    autoApprove: true,
    automerge: true,
    automergeStrategy: 'squash',
    schedule: [],
  },
  osvVulnerabilityAlerts: true,
  gomod: {
    enabled: true,
    commitMessageTopic: '⬆️ golang module {{depName}}',
  },
  docker: {
    enabled: true,
    commitMessageTopic: '⬆️ docker update 🐳 {{depName}}',
  },
  npm: {
    commitMessageTopic: '⬆️ npm update {{depName}}',
    fileMatch: [
      '(^|/)package.json$',
    ],
    rollbackPrs: true,
    versioning: 'npm',
  },
  terraform: {
    commitMessageTopic: '⬆️ terraform update {{depName}}',
    enabled: true,
  },
  packageRules: [
    {
      matchPackagePatterns: [
        'aws-sdk',
      ],
      groupName: 'aws-sdk',
      commitMessageTopic: '☁️ aws sdk {{depName}}',
      prPriority: -1,
    },
    {
      matchPaths: [
        'magefiles',
      ],
      groupName: 'mage-tooling',
      commitMessageTopic: '🤖 mage tooling',
      matchUpdateTypes: [
        'minor',
        'patch',
      ],
      prPriority: -1,
    },
    {
      matchPackagePatterns: [
        'github.com/magefile/mage',
        'github.com/sheldonhull/magetools',
        'github.com/bitfield/script',
        'github.com/pterm/pterm',
      ],
      groupName: 'mage-tooling',
      commitMessageTopic: '🤖 mage tooling',
      matchUpdateTypes: [
        'minor',
        'patch',
      ],
      prPriority: -1,
    },
    {
      matchPackagePatterns: [
        'golang.org/x',
      ],
      groupName: 'go-x',
      commitMessageTopic: 'golang.org/x packages',
      matchUpdateTypes: [
        'minor',
        'patch',
      ],
      prPriority: -1,
    },
    {
      description: 'Opt-out minimum Go version updates: https://github.com/renovatebot/renovate/issues/16715',
      matchManagers: [
        'gomod',
      ],
      matchDepTypes: [
        'golang',
      ],
      enabled: false,
    },
    {
      description: 'Major upgrades: require sheldonhull review and disable automerge',
      matchUpdateTypes: [
        'major',
      ],
      automerge: false,
      autoApprove: false,
      dependencyDashboardApproval: true,
      reviewers: [
        'sheldonhull',
      ],
    },
  ],
}
